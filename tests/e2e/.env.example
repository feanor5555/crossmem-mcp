# CrossMem end-to-end test environment template (task 27.3a+).
#
# Copy this file to ``tests/e2e/.env`` and fill in the values you want
# the runners to use. The real ``tests/e2e/.env`` is gitignored — only
# this example is tracked.
#
# Each variable is listed without a value: setting it is opt-in, and a
# blank value falls back to the documented per-runner default (see
# ``tests/e2e/README.md``).

# Qwen runner (task 27.3a).
# Default when unset / blank: http://192.168.178.45:8080 (developer lab).
# OpenAI-compatible REST endpoint serving the ``qwen-3.5`` model.
CROSSMEM_E2E_QWEN_URL=

# Opus runner (task 27.3b).
# Anthropic Claude Opus via the official Messages API.
# No default — unset / blank means the runner skips with status "skipped"
# so contributors without an Anthropic account see a clean skip instead
# of a hard failure. Get a key at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Mock runner (task 27.3c).
# The in-process MockLLMServer is always available, so this variable
# does NOT need to be set ahead of time — the mock runner exports it
# automatically when it spins the server up. The line below documents
# the contract so scenarios know which env var to read.
CROSSMEM_E2E_MOCK_URL=
